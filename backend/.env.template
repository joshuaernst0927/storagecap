# ── Anthropic (required for letter drafting) ──────────────────────────────────
ANTHROPIC_API_KEY=

# ── ATTOM Data API (strongly recommended — unlocks owner + distress signals) ──
# https://api.developer.attomdata.com/  |  free trial available
ATTOM_API_KEY=

# ── CoStar / LoopNet API (optional — premium listings) ────────────────────────
# CoStar Group API — contact sales@costar.com for access
COSTAR_API_KEY=
COSTAR_API_SECRET=

# ── Crexi API (optional — FSBO + marketed listings) ───────────────────────────
# https://app.crexi.com/api-docs
CREXI_API_KEY=

# ── Email summary ─────────────────────────────────────────────────────────────
# Gmail: use an App Password (not your account password)
# https://myaccount.google.com/apppasswords
EMAIL_USERNAME=joshuaernst@gmail.com
EMAIL_PASSWORD=
EMAIL_TO=joshuaernst@gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# ── Next.js pipeline integration ──────────────────────────────────────────────
NEXTJS_BASE_URL=http://localhost:3000
# Optional — add to /api/pipeline-ingest.ts if you want auth
NEXTJS_API_SECRET=

# ── Pipeline settings ─────────────────────────────────────────────────────────
TARGET_STATES=FL,TX,NC,GA,TN
HOT_DEAL_THRESHOLD=65
DEALS_JSON_PATH=deals.json

# ── Scraper behavior ──────────────────────────────────────────────────────────
# Seconds to wait between requests (be respectful)
REQUEST_DELAY_SECONDS=2
# Set to 1 to use Playwright for JS-heavy sites (run: playwright install chromium)
USE_PLAYWRIGHT=1
